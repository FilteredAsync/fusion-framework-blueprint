        <Item class="ModuleScript" referent="RBX91">
          <Properties>
            <string name="Name">ShopScreen</string>
            <ProtectedString name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Fusion = require(ReplicatedStorage.Fusion)
local theme = require(script.Parent.Parent.theme)
local Panel = require(script.Parent.Parent.components.base.Panel)
local ItemCard = require(script.Parent.Parent.components.common.ItemCard)
local items = require(script.Parent.Parent.configs.items)

local Children = Fusion.Children

local function ShopScreen(scope: Fusion.Scope&lt;any&gt;, props: { Stores: any })
	local player = props.Stores.Player

	local itemState = scope:Value(items)

	local cards = scope:ForValues(itemState, function(use, itemScope, item)
		return ItemCard(itemScope, {
			Item = item,
			Owned = itemScope:Computed(function(use2)
				return table.find(use2(player.OwnedIds), item.id) ~= nil
			end),
			CanAfford = itemScope:Computed(function(use2)
				return use2(player.Coins) &gt;= item.price
			end),
			OnBuy = function(bought)
				if player.Spend(bought.price) then
					player.AddOwned(bought.id)
				end
			end,
		})
	end)

	return Panel(scope, {
		Name = "ShopScreen",
		Size = UDim2.fromOffset(420, 460),
		Position = UDim2.fromScale(0.5, 0.5),
		AnchorPoint = Vector2.new(0.5, 0.5),
		Content = {
			scope:New "TextLabel" {
				Size = UDim2.new(1, 0, 0, 28),
				BackgroundTransparency = 1,
				Text = "Shop",
				TextColor3 = theme.palette.text,
				FontFace = theme.fontBold,
				TextSize = 20,
				TextXAlignment = Enum.TextXAlignment.Left,
			},
			scope:New "ScrollingFrame" {
				Size = UDim2.new(1, 0, 1, -36),
				Position = UDim2.fromOffset(0, 36),
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				CanvasSize = UDim2.new(),
				AutomaticCanvasSize = Enum.AutomaticSize.Y,
				ScrollBarThickness = 4,
				[Children] = {
					scope:New "UIListLayout" {
						Padding = UDim.new(0, 6),
						SortOrder = Enum.SortOrder.LayoutOrder,
					},
					cards,
				},
			},
		},
	})
end

return ShopScreen
</ProtectedString>
          </Properties>
        </Item>
