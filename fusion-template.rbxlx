		accent = Color3.fromRGB(88, 182, 226),
		text = Color3.fromRGB(235, 240, 245),
		textDim = Color3.fromRGB(150, 160, 172),
		danger = Color3.fromRGB(226, 96, 96),
		success = Color3.fromRGB(112, 200, 128),
	}),
	font = Font.fromEnum(Enum.Font.GothamMedium),
	fontBold = Font.fromEnum(Enum.Font.GothamBold),
	corner = UDim.new(0, 8),
	pad = 10,
	textSize = 16,
}

return table.freeze(theme)
</ProtectedString>
