      <Item class="ModuleScript" referent="RBX88">
        <Properties>
          <string name="Name">Router</string>
          <ProtectedString name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Fusion = require(ReplicatedStorage.Fusion)

export type Screen = (scope: Fusion.Scope&lt;any&gt;, props: any) -&gt; Instance

local function Router(appScope: Fusion.Scope&lt;any&gt;, screens: { [string]: Screen }, mountTarget: Instance)
	local current = appScope:Value(nil :: string?)
	local screenScope = nil

	local router = {
		Current = current,
	}

	function router.Navigate(name: string?, props: any?)
		if screenScope then
			Fusion.doCleanup(screenScope)
			screenScope = nil
		end

		local screen = if name then screens[name] else nil
		if not screen then
			current:set(nil)
			return
		end

		screenScope = appScope:innerScope()
		local ui = screen(screenScope, props or {})
		ui.Parent = mountTarget
		current:set(name)
	end

	function router.Close()
		router.Navigate(nil)
	end

	function router.Toggle(name: string, props: any?)
		if Fusion.peek(current) == name then
			router.Close()
		else
			router.Navigate(name, props)
		end
	end

	return router
end

return Router
</ProtectedString>
        </Properties>
      </Item>
      <Item class="Folder" referent="RBX89">
