      <Item class="Folder" referent="RBX92">
        <Properties>
          <string name="Name">stores</string>
        </Properties>
        <Item class="ModuleScript" referent="RBX93">
          <Properties>
            <string name="Name">PlayerStore</string>
            <ProtectedString name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Fusion = require(ReplicatedStorage.Fusion)
local peek = Fusion.peek

export type Snapshot = {
	Coins: number,
	Level: number,
	OwnedIds: { number },
}

local function PlayerStore(scope: Fusion.Scope&lt;any&gt;)
	local coins = scope:Value(0)
	local level = scope:Value(1)
	local ownedIds = scope:Value(table.freeze({}))

	local store = {
		Coins = coins,
		Level = level,
		OwnedIds = ownedIds,
	}

	function store.ApplySnapshot(data: Snapshot)
		coins:set(data.Coins)
		level:set(data.Level)
		ownedIds:set(table.freeze(table.clone(data.OwnedIds)))
	end

	function store.Earn(amount: number)
		coins:set(peek(coins) + amount)
	end

	function store.Spend(amount: number): boolean
		local current = peek(coins)
		if current &lt; amount then
			return false
		end
		coins:set(current - amount)
		return true
	end

	function store.AddOwned(id: number)
		local next = table.clone(peek(ownedIds))
		table.insert(next, id)
		ownedIds:set(table.freeze(next))
	end

	return store
end

return PlayerStore
</ProtectedString>
          </Properties>
        </Item>
      </Item>
      <Item class="ModuleScript" referent="RBX94">
