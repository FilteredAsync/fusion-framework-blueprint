          <Item class="ModuleScript" referent="RBX85">
            <Properties>
              <string name="Name">ItemCard</string>
              <ProtectedString name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Fusion = require(ReplicatedStorage.Fusion)
local theme = require(script.Parent.Parent.Parent.theme)
local Button = require(script.Parent.Parent.base.Button)

local Children = Fusion.Children

export type Item = {
	id: number,
	name: string,
	price: number,
}

export type Props = {
	Item: Item,
	Owned: Fusion.UsedAs&lt;boolean&gt;?,
	CanAfford: Fusion.UsedAs&lt;boolean&gt;?,
	OnBuy: ((Item) -&gt; ())?,
	LayoutOrder: Fusion.UsedAs&lt;number&gt;?,
}

local function ItemCard(scope: Fusion.Scope&lt;any&gt;, props: Props)
	local item = props.Item

	local buyText = scope:Computed(function(use)
		if use(props.Owned) then
			return "Owned"
		end
		return `Buy · {item.price}`
	end)

	local disabled = scope:Computed(function(use)
		return use(props.Owned) or not use(props.CanAfford)
	end)

	return scope:New "Frame" {
		Name = item.name,
		Size = UDim2.new(1, 0, 0, 56),
		BackgroundColor3 = theme.palette.panelLight,
		BorderSizePixel = 0,
		LayoutOrder = props.LayoutOrder or item.id,

		[Children] = {
			scope:New "UICorner" { CornerRadius = theme.corner },
			scope:New "TextLabel" {
				Size = UDim2.new(1, -130, 1, 0),
				Position = UDim2.fromOffset(theme.pad, 0),
				BackgroundTransparency = 1,
				Text = item.name,
				TextColor3 = theme.palette.text,
				FontFace = theme.font,
				TextSize = theme.textSize,
				TextXAlignment = Enum.TextXAlignment.Left,
			},
			Button(scope, {
				Text = buyText,
				Disabled = disabled,
				Size = UDim2.fromOffset(110, 36),
				Position = UDim2.new(1, -theme.pad, 0.5, 0),
				AnchorPoint = Vector2.new(1, 0.5),
				OnClick = function()
					if props.OnBuy then
						props.OnBuy(item)
					end
				end,
			}),
		},
	}
end

return ItemCard
</ProtectedString>
            </Properties>
          </Item>
        </Item>
