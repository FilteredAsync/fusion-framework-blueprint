  <Item class="StarterPlayer" referent="RBX95">
    <Properties><string name="Name">StarterPlayer</string></Properties>
    <Item class="StarterPlayerScripts" referent="RBX96">
      <Properties><string name="Name">StarterPlayerScripts</string></Properties>
      <Item class="LocalScript" referent="RBX97">
        <Properties>
          <string name="Name">App</string>
          <ProtectedString name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local Fusion = require(ReplicatedStorage.Fusion)
local UI = ReplicatedStorage.UIFramework

local theme = require(UI.theme)
local Button = require(UI.components.base.Button)
local Panel = require(UI.components.base.Panel)
local PlayerStore = require(UI.stores.PlayerStore)
local Router = require(UI.Router)
local HubScreen = require(UI.screens.HubScreen)
local ShopScreen = require(UI.screens.ShopScreen)

local scoped = Fusion.scoped
local Children = Fusion.Children

local scope = scoped(Fusion, {
	Button = Button,
	Panel = Panel,
})

local stores = {
	Player = PlayerStore(scope),
}

local gui = scope:New "ScreenGui" {
	Name = "FusionApp",
	ResetOnSpawn = false,
	IgnoreGuiInset = true,
}
gui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

local screenHost = scope:New "Frame" {
	Name = "ScreenHost",
	Size = UDim2.fromScale(1, 1),
	BackgroundTransparency = 1,
}
screenHost.Parent = gui

local router = Router(scope, {
	Hub = function(s, p)
		return HubScreen(s, { Stores = stores })
	end,
	Shop = function(s, p)
		return ShopScreen(s, { Stores = stores })
	end,
}, screenHost)

local hud = scope:New "Frame" {
	Name = "HUD",
	Size = UDim2.new(1, 0, 0, 56),
	BackgroundColor3 = theme.palette.bg,
	BorderSizePixel = 0,
	[Children] = {
		scope:New "TextLabel" {
			Name = "CoinLabel",
			Size = UDim2.fromOffset(180, 36),
			Position = UDim2.new(0, theme.pad, 0.5, 0),
			AnchorPoint = Vector2.new(0, 0.5),
			BackgroundTransparency = 1,
			Text = scope:Computed(function(use)
				return `⛁ {use(stores.Player.Coins)}`
			end),
			TextColor3 = theme.palette.accent,
			FontFace = theme.fontBold,
			TextSize = 20,
			TextXAlignment = Enum.TextXAlignment.Left,
		},
		scope:New "Frame" {
			Size = UDim2.new(0, 300, 1, 0),
			Position = UDim2.new(1, -theme.pad, 0, 0),
			AnchorPoint = Vector2.new(1, 0),
			BackgroundTransparency = 1,
			[Children] = {
				scope:New "UIListLayout" {
					FillDirection = Enum.FillDirection.Horizontal,
					HorizontalAlignment = Enum.HorizontalAlignment.Right,
					VerticalAlignment = Enum.VerticalAlignment.Center,
					Padding = UDim.new(0, 8),
				},
				scope:Button {
					Text = "Hub",
					Size = UDim2.fromOffset(90, 36),
					OnClick = function()
						router.Navigate("Hub")
					end,
				},
				scope:Button {
					Text = "Shop",
					Size = UDim2.fromOffset(90, 36),
					OnClick = function()
						router.Toggle("Shop")
					end,
				},
			},
		},
	},
}
hud.Parent = gui

task.spawn(function()
	stores.Player.ApplySnapshot({ Coins = 100, Level = 3, OwnedIds = {} })
	while task.wait(1) do
		stores.Player.Earn(5)
	end
end)

router.Navigate("Hub")
</ProtectedString>
        </Properties>
      </Item>
    </Item>
  </Item>
</roblox>
