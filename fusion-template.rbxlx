          <Item class="ModuleScript" referent="RBX81">
            <Properties>
              <string name="Name">Button</string>
              <ProtectedString name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Fusion = require(ReplicatedStorage.Fusion)
local theme = require(script.Parent.Parent.Parent.theme)

local OnEvent, Children, peek = Fusion.OnEvent, Fusion.Children, Fusion.peek

export type Props = {
	Text: Fusion.UsedAs&lt;string&gt;?,
	Disabled: Fusion.UsedAs&lt;boolean&gt;?,
	OnClick: (() -&gt; ())?,
	Size: Fusion.UsedAs&lt;UDim2&gt;?,
	Position: Fusion.UsedAs&lt;UDim2&gt;?,
	AnchorPoint: Fusion.UsedAs&lt;Vector2&gt;?,
	LayoutOrder: Fusion.UsedAs&lt;number&gt;?,
}

local function Button(scope: Fusion.Scope&lt;any&gt;, props: Props)
	local hovering = scope:Value(false)

	local targetColor = scope:Computed(function(use)
		if use(props.Disabled) then
			return theme.palette.panel
		end
		return if use(hovering) then theme.palette.accent else theme.palette.panelLight
	end)

	return scope:New "TextButton" {
		Size = props.Size or UDim2.fromOffset(140, 40),
		Position = props.Position,
		AnchorPoint = props.AnchorPoint,
		LayoutOrder = props.LayoutOrder,
		BackgroundColor3 = scope:Spring(targetColor, 30, 1),
		Text = props.Text or "Button",
		TextColor3 = theme.palette.text,
		FontFace = theme.fontBold,
		TextSize = theme.textSize,
		AutoButtonColor = false,

		[OnEvent "MouseEnter"] = function()
			hovering:set(true)
		end,
		[OnEvent "MouseLeave"] = function()
			hovering:set(false)
		end,
		[OnEvent "Activated"] = function()
			if props.OnClick and not peek(props.Disabled) then
				props.OnClick()
			end
		end,

		[Children] = {
			scope:New "UICorner" { CornerRadius = theme.corner },
		},
	}
end

return Button
</ProtectedString>
            </Properties>
          </Item>
